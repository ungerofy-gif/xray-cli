# Telegram bot token from BotFather
TG_BOT_TOKEN=123456789:YOUR_TOKEN

# Comma-separated Telegram user IDs allowed to use bot
TG_ALLOWED_USER_IDS=111111111,222222222

# Optional: override API URL directly
# API_BASE_URL=http://127.0.0.1:2053

# API values are read from /etc/default/xraycli-api by default
# API_HOST=127.0.0.1
# API_PORT=2053
# API_KEY=change-me

API_TIMEOUT=10s
METRICS_TIMEOUT=3s
COMMAND_TIMEOUT=20s
USERS_PER_PAGE=8
SYSTEM_ENV_FILE=/etc/default/xraycli-api
